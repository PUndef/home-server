      "hostname": "192.168.50.9",
      "interval": 60
    },
    {
      "group": "srv (Proxmox / VMs)",
      "type": "port",
      "name": "Proxmox UI :8006",
      "hostname": "192.168.50.9",
      "port": 8006,
      "interval": 120
    },
    {
      "group": "srv (Proxmox / VMs)",
      "type": "ping",
      "name": "nextcloud-vm",
      "hostname": "192.168.50.34",
      "interval": 60
    },
    {
      "group": "srv (Proxmox / VMs)",
      "type": "ping",
      "name": "owncord LXC",
      "hostname": "192.168.50.36",
      "interval": 60
    },
    {
      "group": "srv (Proxmox / VMs)",
      "type": "ping",
      "name": "phoneserver",
      "hostname": "192.168.50.127",
      "interval": 60
    },
    {
      "group": "LAN",
