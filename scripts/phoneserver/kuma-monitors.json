{
  "_note": "Lean set for Kuma on static-sites (.35). No duplicate LAN+public checks for same service.",
  "groups": [
    "Public HTTPS",
    "srv (Proxmox / VMs)",
    "LAN",
    "VPS"
  ],
  "monitors": [
    {
      "group": "Public HTTPS",
      "type": "http",
      "name": "Nextcloud",
      "url": "https://cloud-pundef.mooo.com/",
      "interval": 60,
      "maxretries": 3,
      "ignoreTls": true,
      "acceptedStatusCodes": ["200-299", "300-399"]
    },
    {
      "group": "Public HTTPS",
      "type": "http",
      "name": "Beszel hub",
      "url": "https://apps-pundef.mooo.com/beszel/api/health",
      "interval": 60,
      "ignoreTls": true,
      "acceptedStatusCodes": ["200-299"]
    },
    {
      "group": "Public HTTPS",
      "type": "http",
      "name": "OwnCord",
      "url": "https://owncord-pundef.mooo.com/api/health",
      "interval": 60,
      "maxretries": 3,
      "ignoreTls": true,
      "acceptedStatusCodes": ["200-299"]
    },
    {
      "group": "srv (Proxmox / VMs)",
      "type": "http",
      "name": "Requiem (static)",
      "url": "http://192.168.50.35/requiem/",
      "interval": 120,
      "acceptedStatusCodes": ["200-299"]
    },
    {
      "group": "srv (Proxmox / VMs)",
      "type": "ping",
