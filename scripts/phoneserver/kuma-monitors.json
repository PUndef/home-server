      "interval": 60
    },
    {
      "group": "srv (Proxmox / VMs)",
      "type": "http",
      "name": "Home Assistant (phoneserver)",
      "url": "http://192.168.50.127:8123/",
      "interval": 120,
      "acceptedStatusCodes": ["200-299", "300-399"]
    },
    {
      "group": "VPS",
      "type": "ping",
      "name": "fin-sweet-home-vps",
      "hostname": "89.44.76.52",
      "interval": 120
