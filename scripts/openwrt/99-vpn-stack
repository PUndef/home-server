#!/bin/sh
# Stabilize VPN stack on wan/awg ifup events.
# Re-add github routes via awg2 (used to fetch community lists; main outbound
# tunnel since 2026-06-02 after awg1 / Fin went silent) and restart
# sing-box -> podkop -> zapret -> pbr in the right order so the routing stack
# survives reboots, link flaps, and provider/wan reconnects.

[ "$ACTION" = "ifup" ] || exit 0

case "$INTERFACE" in
  wan|awg1|awg2)
    ip route replace 185.199.108.0/22 dev awg2 2>/dev/null
    ip route replace 140.82.112.0/20 dev awg2 2>/dev/null
    sleep 10
    /etc/init.d/sing-box restart 2>/dev/null
    /etc/init.d/podkop restart 2>/dev/null
    /etc/init.d/zapret restart
    /etc/init.d/pbr restart
    if [ -f /etc/destiny-login-mode ]; then
      case "$(cat /etc/destiny-login-mode 2>/dev/null)" in
        full) sh /opt/destiny-login-mode.sh --full 2>/dev/null || true ;;
        *) sh /opt/destiny-login-mode.sh 2>/dev/null || true ;;
      esac
    else
      sh /opt/apply-pundef-pc-routes.sh 2>/dev/null || true
    fi
    sh /opt/seed-phoneserver-groq-ips.sh 2>/dev/null || true
    ;;
  workvpn)
    # Rebuild pbr_workvpn routes after OpenConnect reconnect; full stack not needed.
    sleep 5
    /etc/init.d/pbr restart
    if [ -f /etc/destiny-login-mode ]; then
      case "$(cat /etc/destiny-login-mode 2>/dev/null)" in
        full) sh /opt/destiny-login-mode.sh --full 2>/dev/null || true ;;
        *) sh /opt/destiny-login-mode.sh 2>/dev/null || true ;;
      esac
    else
      sh /opt/apply-pundef-pc-routes.sh 2>/dev/null || true
    fi
    sh /opt/seed-phoneserver-groq-ips.sh 2>/dev/null || true
    ;;
esac
